rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn() && userProfile().data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isDiretoria() {
      return hasRole('diretoria') || isAdmin();
    }

    function hasAdminSection(section) {
      return isAdmin()
        || (signedIn()
          && userProfile().data.adminSectionAccess is list
          && userProfile().data.adminSectionAccess.hasAny([section]));
    }

    function protectedProfileFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['possuiCargo', 'cargo', 'outroCargo', 'dataBatismo']);
    }

    function selfProfileUpdate() {
      return request.resource.data.role == resource.data.role
        && protectedProfileFieldsUnchanged();
    }

    function selfVisitorActivation() {
      return resource.data.role == 'pendente'
        && request.resource.data.role == 'visitante'
        && protectedProfileFieldsUnchanged();
    }

    function selfLinkedProfileActivation() {
      return resource.data.role == 'pendente'
        && request.resource.data.emailLower == resource.data.emailLower
        && request.resource.data.role in ['visitante', 'congregado', 'membro', 'pendente']
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['possuiCargo', 'cargo', 'outroCargo', 'dataBatismo']);
    }

    function emailMatchesSignedInUser() {
      return signedIn()
        && resource.data.emailLower == request.auth.token.email;
    }

    function registrationClaimFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['userId', 'linkedBy', 'linkedAt', 'updatedAt']);
    }

    function registrationIsUnclaimedOrSelf() {
      return !resource.data.keys().hasAny(['userId'])
        || resource.data.userId == null
        || resource.data.userId == request.auth.uid;
    }

    function approvalPromotesMemberAccess() {
      return hasAdminSection('aprovacao_cadastros')
        && resource.data.role == 'pendente'
        && request.resource.data.role == 'membro';
    }

    match /siteSettings/{document=**} {
      allow read: if true;
      allow write: if hasAdminSection('site');
    }

    match /congregations/{document=**} {
      allow read: if true;
      allow write: if hasAdminSection('congregacoes');
    }

    match /events/{document=**} {
      allow read: if true;
      allow write: if isDiretoria();
    }

    match /announcements/{document=**} {
      allow read: if signedIn();
      allow write: if isDiretoria();
    }

    match /membershipRequests/{requestId} {
      allow create: if signedIn();
      allow read: if isDiretoria()
        || hasAdminSection('cadastros')
        || hasAdminSection('aprovacao_cadastros')
        || emailMatchesSignedInUser();
      allow update: if hasAdminSection('aprovacao_cadastros')
        || (emailMatchesSignedInUser() && registrationIsUnclaimedOrSelf() && registrationClaimFieldsOnly());
      allow delete: if hasAdminSection('aprovacao_cadastros');
    }

    match /visitRecords/{recordId} {
      allow create: if signedIn()
        && (request.resource.data.userId == request.auth.uid || isDiretoria() || hasAdminSection('presencas'));
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid
          || isDiretoria()
          || hasAdminSection('dashboard_registros')
          || hasAdminSection('relatorio_visitantes'));
      allow update: if signedIn()
        && (
          (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
          || isDiretoria()
          || hasAdminSection('dashboard_registros')
        );
      allow delete: if hasAdminSection('dashboard_registros');
    }

    match /users/{userId} {
      allow create: if (signedIn() && request.auth.uid == userId
          && request.resource.data.role == 'pendente')
        || isAdmin();
      allow read: if signedIn()
        && (request.auth.uid == userId
          || isDiretoria()
          || hasAdminSection('usuarios')
          || hasAdminSection('aprovacao_cadastros'));
      allow update: if (signedIn() && request.auth.uid == userId
          && (selfProfileUpdate() || selfVisitorActivation() || selfLinkedProfileActivation()))
        || isAdmin()
        || approvalPromotesMemberAccess();
      allow delete: if isAdmin();
    }

    match /members/{memberId} {
      allow read: if hasAdminSection('membros') || emailMatchesSignedInUser();
      allow create: if hasAdminSection('membros') || hasAdminSection('aprovacao_cadastros');
      allow update: if hasAdminSection('membros')
        || (emailMatchesSignedInUser() && registrationIsUnclaimedOrSelf() && registrationClaimFieldsOnly());
      allow delete: if hasAdminSection('membros');
    }

    match /serviceSchedules/{document=**} {
      allow read: if signedIn();
      allow write: if isDiretoria();
    }

    match /sermonAssignments/{document=**} {
      allow read: if signedIn();
      allow write: if isDiretoria();
    }

    match /communionSchedules/{document=**} {
      allow read: if signedIn();
      allow write: if isDiretoria();
    }

    match /auditLogs/{document=**} {
      allow read: if hasAdminSection('auditoria');
      allow create: if signedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /memberCards/{cardId} {
      allow read: if signedIn()
        && (cardId == request.auth.uid || isDiretoria() || hasAdminSection('membros'));
      allow create, update: if signedIn()
        && (
          (cardId == request.auth.uid && request.resource.data.status == 'solicitado')
          || hasAdminSection('membros')
        );
      allow delete: if hasAdminSection('membros');
    }

    match /notifications/{notificationId} {
      allow create: if signedIn();
      allow read, update: if isDiretoria() || hasAdminSection('membros');
      allow delete: if isAdmin();
    }
  }
}
