rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /member-documents/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /admin-documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
